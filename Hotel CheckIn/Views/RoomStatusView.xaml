<UserControl x:Class="Hotel_CheckIn.Views.RoomStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
	<Grid>
		<Border Background="{DynamicResource BgDark}" CornerRadius="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="30" Width="500">
			<Border.Effect>
				<DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.1"/>
			</Border.Effect>
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<TextBlock Text="Room Status" Grid.Row="0" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20" HorizontalAlignment="Center"/>
				<Border Grid.Row="1" CornerRadius="8" BorderThickness="1" BorderBrush="#334155" Background="{DynamicResource ElementBg}" ClipToBounds="True">
					<ListView x:Name="RoomStatusList" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" HorizontalContentAlignment="Stretch">
						<ListView.Resources>
							<Style TargetType="GridViewColumnHeader">
								<Setter Property="Background" Value="{DynamicResource SidebarDark}"/>
								<Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
								<Setter Property="FontWeight" Value="SemiBold"/>
								<Setter Property="Padding" Value="15,12"/>
								<Setter Property="BorderThickness" Value="0,0,0,1"/>
								<Setter Property="BorderBrush" Value="#334155"/>
								<Setter Property="HorizontalContentAlignment" Value="Left"/>
							</Style>
							<Style TargetType="ListViewItem">
								<Setter Property="Focusable" Value="False"/>
								<Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
								<Setter Property="Template">
									<Setter.Value>
										<ControlTemplate TargetType="ListViewItem">
											<Border x:Name="Bd" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#334155" Padding="5,10">
												<GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
											</Border>
											<ControlTemplate.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter TargetName="Bd" Property="Background" Value="{DynamicResource ElementBg}"/>
													<Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
												</Trigger>
											</ControlTemplate.Triggers>
										</ControlTemplate>
									</Setter.Value>
								</Setter>
							</Style>
						</ListView.Resources>
						<ListView.View>
							<GridView>
								<GridViewColumn Header="Room" Width="100" DisplayMemberBinding="{Binding RoomNumber}" />
								<GridViewColumn Header="Status" Width="120" DisplayMemberBinding="{Binding Status}" />
								<GridViewColumn Header="Guest" Width="200" DisplayMemberBinding="{Binding GuestName}" />
							</GridView>
						</ListView.View>
					</ListView>
				</Border>
			</Grid>
		</Border>
	</Grid>
</UserControl>