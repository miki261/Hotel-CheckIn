<UserControl x:Class="Hotel_CheckIn.Views.RoomStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">

	<Grid Margin="30">
		<StackPanel>
			<TextBlock Text="Room Status"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,0,0,20"/>

			<Border Background="#1E293B"
                    CornerRadius="12"
                    Padding="10">
				<ListView x:Name="RoomStatusList"
                          Background="#1E293B"
                          Foreground="White"
                          BorderThickness="0"
                          HorizontalContentAlignment="Stretch">

					<ListView.Resources>
						<Style TargetType="GridViewColumnHeader">
							<Setter Property="Background" Value="#334155"/>
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="FontWeight" Value="Bold"/>
							<Setter Property="Padding" Value="10"/>
						</Style>

						<Style TargetType="ListViewItem">
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="Background" Value="#1E293B"/>
							<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
						</Style>
					</ListView.Resources>

					<ListView.View>
						<GridView>
							<GridViewColumn Header="Room" Width="120" DisplayMemberBinding="{Binding RoomNumber}" />
							<GridViewColumn Header="Status" Width="160" DisplayMemberBinding="{Binding Status}" />
							<GridViewColumn Header="Guest" Width="220" DisplayMemberBinding="{Binding GuestName}" />
						</GridView>
					</ListView.View>
				</ListView>
			</Border>
		</StackPanel>
	</Grid>
</UserControl>