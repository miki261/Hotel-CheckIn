<UserControl x:Class="Hotel_CheckIn.Views.NewGuestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">

	<Grid Margin="30">
		<StackPanel Width="350">

			<TextBlock Text="New Guest"
                       FontSize="24"
                       Foreground="White"
                       Margin="0,0,0,20"/>

			<TextBlock Text="Full Name" Foreground="White"/>
			<TextBox x:Name="NameTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="ID / Passport" Foreground="White"/>
			<TextBox x:Name="IdTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="Room Number" Foreground="White"/>
			<TextBox x:Name="RoomTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="Check-In Date" Foreground="White" Margin="0,10,0,0"/>
			<DatePicker x:Name="CheckInDatePicker" Margin="0,5"/>

			<TextBlock Text="Check-In Time" Foreground="White"/>
			<ComboBox x:Name="CheckInTimeComboBox" Margin="0,5" Height="30">
				<ComboBoxItem Content="12:00"/>
				<ComboBoxItem Content="13:00"/>
				<ComboBoxItem Content="14:00"/>
				<ComboBoxItem Content="15:00"/>
				<ComboBoxItem Content="16:00"/>
				<ComboBoxItem Content="17:00"/>
				<ComboBoxItem Content="18:00"/>
				<ComboBoxItem Content="19:00"/>
				<ComboBoxItem Content="20:00"/>
			</ComboBox>

			<TextBlock Text="Check-Out Date" Foreground="White" Margin="0,10,0,0"/>
			<DatePicker x:Name="CheckOutDatePicker" Margin="0,5"/>

			<TextBlock Text="Check-Out Time" Foreground="White"/>
			<ComboBox x:Name="CheckOutTimeComboBox" Margin="0,5" Height="30">
				<ComboBoxItem Content="10:00"/>
				<ComboBoxItem Content="11:00"/>
				<ComboBoxItem Content="12:00"/>
				<ComboBoxItem Content="13:00"/>
				<ComboBoxItem Content="14:00"/>
			</ComboBox>

			<Button Content="Check In"
                    Height="40"
                    Background="#2563EB"
                    Foreground="White"
                    Margin="0,15,0,0"
                    Click="CheckIn_Click"/>
		</StackPanel>
	</Grid>
</UserControl>