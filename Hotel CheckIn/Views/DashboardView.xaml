<UserControl x:Class="Hotel_CheckIn.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

	<UserControl.Resources>
		<Style x:Key="PrimaryButton" TargetType="Button">
			<Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="15,10"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#2563EB"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="DangerButton" TargetType="Button">
			<Setter Property="Background" Value="#EF4444"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="15,10"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#DC2626"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<Grid>
		<Border Background="{DynamicResource BgDark}" CornerRadius="12" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="30">
			<Border.Effect>
				<DropShadowEffect BlurRadius="30" ShadowDepth="4" Direction="270" Color="Black" Opacity="0.1"/>
			</Border.Effect>

			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<StackPanel Grid.Row="0" Margin="0,0,0,30">
					<TextBlock Text="Dashboard Overview" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
					<TextBlock Text="Welcome back! Here is today's summary." FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,5,0,0"/>
				</StackPanel>

				<Grid Grid.Row="1">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>

						<Border Grid.Column="0" Background="{DynamicResource ElementBg}" CornerRadius="10" BorderThickness="1" BorderBrush="#334155" Padding="20" Margin="0,0,10,0">
							<StackPanel>
								<TextBlock Text="Active Guests" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
								<TextBlock x:Name="ActiveReservationsText" Text="0" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource AccentBlue}" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>

						<Border Grid.Column="1" Background="{DynamicResource ElementBg}" CornerRadius="10" BorderThickness="1" BorderBrush="#334155" Padding="20" Margin="5,0,5,0">
							<StackPanel>
								<TextBlock Text="Checked Out" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
								<TextBlock x:Name="CheckedOutTodayText" Text="0" FontSize="32" FontWeight="Bold" Foreground="#10B981" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>

						<Border Grid.Column="2" Background="{DynamicResource ElementBg}" CornerRadius="10" BorderThickness="1" BorderBrush="#334155" Padding="20" Margin="5,0,5,0">
							<StackPanel>
								<TextBlock Text="Total History" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
								<TextBlock x:Name="TotalGuestsText" Text="0" FontSize="32" FontWeight="Bold" Foreground="#F59E0B" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>

						<Border Grid.Column="3" Background="{DynamicResource ElementBg}" CornerRadius="10" BorderThickness="1" BorderBrush="#334155" Padding="20" Margin="10,0,0,0">
							<StackPanel>
								<TextBlock Text="Occupied Rooms" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}"/>
								<TextBlock x:Name="OccupiedRoomsText" Text="0" FontSize="32" FontWeight="Bold" Foreground="#8B5CF6" Margin="0,5,0,0"/>
							</StackPanel>
						</Border>
					</Grid>

					<Border Grid.Row="1" Background="{DynamicResource ElementBg}" CornerRadius="10" BorderThickness="1" BorderBrush="#334155" Padding="25" Margin="0,20,0,0" VerticalAlignment="Top">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<TextBlock Grid.Row="0" Text="Database Management" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,5"/>
							<TextBlock Grid.Row="1" Text="Secure your data by creating local backups, or restore previous states in case of an error." FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"/>

							<Border Grid.Row="2" Background="{DynamicResource BgDark}" CornerRadius="8" Padding="15">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>

									<StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
										<TextBlock Text="💾" FontSize="20" Margin="0,0,10,0"/>
										<TextBlock x:Name="LastBackupText" Text="Last backup: Checking..." FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
									</StackPanel>

									<Button Grid.Column="1" Content="Backup Database" Click="BackupDatabase_Click" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
									<Button Grid.Column="2" Content="Restore System" Click="RestoreDatabase_Click" Style="{StaticResource DangerButton}"/>
								</Grid>
							</Border>
						</Grid>
					</Border>
				</Grid>
			</Grid>
		</Border>
	</Grid>
</UserControl>