<UserControl x:Class="Hotel_CheckIn.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">

	<Grid Margin="30">
		<ScrollViewer VerticalScrollBarVisibility="Auto">
			<StackPanel>
				<TextBlock Text="Dashboard"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,20"/>

				<WrapPanel Margin="0,0,0,20">
					<Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,15,15" Width="180">
						<StackPanel>
							<TextBlock Text="Active Reservations"
                                       Foreground="#CBD5E1"
                                       FontSize="14"/>
							<TextBlock x:Name="ActiveReservationsText"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,8,0,0"/>
						</StackPanel>
					</Border>

					<Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,15,15" Width="180">
						<StackPanel>
							<TextBlock Text="Checked Out Today"
                                       Foreground="#CBD5E1"
                                       FontSize="14"/>
							<TextBlock x:Name="CheckedOutTodayText"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,8,0,0"/>
						</StackPanel>
					</Border>

					<Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,15,15" Width="180">
						<StackPanel>
							<TextBlock Text="Total Guests"
                                       Foreground="#CBD5E1"
                                       FontSize="14"/>
							<TextBlock x:Name="TotalGuestsText"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,8,0,0"/>
						</StackPanel>
					</Border>

					<Border Background="#1E293B" CornerRadius="12" Padding="20" Margin="0,0,15,15" Width="180">
						<StackPanel>
							<TextBlock Text="Occupied Rooms"
                                       Foreground="#CBD5E1"
                                       FontSize="14"/>
							<TextBlock x:Name="OccupiedRoomsText"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,8,0,0"/>
						</StackPanel>
					</Border>
				</WrapPanel>

				<Border Background="#1E293B" CornerRadius="12" Padding="20">
					<StackPanel>
						<TextBlock Text="Database Tools"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,15"/>

						<TextBlock x:Name="LastBackupText"
                                   Foreground="#CBD5E1"
                                   Margin="0,0,0,15"
                                   Text="Last backup: Never"/>

						<TextBlock Text="Create a backup of your current database or restore a previous one."
                                   Foreground="#CBD5E1"
                                   Margin="0,0,0,15"
                                   TextWrapping="Wrap"/>

						<StackPanel Orientation="Horizontal">
							<Button Content="Backup Database"
                                    Width="150"
                                    Height="38"
                                    Margin="0,0,10,0"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="BackupDatabase_Click"/>

							<Button Content="Restore Database"
                                    Width="150"
                                    Height="38"
                                    Background="#DC2626"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="RestoreDatabase_Click"/>
						</StackPanel>
					</StackPanel>
				</Border>
			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>