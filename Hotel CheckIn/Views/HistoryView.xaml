<UserControl x:Class="Hotel_CheckIn.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F172A">

	<Grid Margin="30">
		<StackPanel>
			<TextBlock Text="Past Reservations"
                       FontSize="24"
                       Foreground="White"
                       Margin="0,0,0,20"/>

			<ListView x:Name="HistoryList"
                      Height="320"
                      Background="#0F172A"
                      Foreground="White"
                      BorderBrush="#334155"
                      BorderThickness="1"
                      HorizontalContentAlignment="Stretch">

				<ListView.Resources>
					<Style TargetType="GridViewColumnHeader">
						<Setter Property="Background" Value="#1E293B"/>
						<Setter Property="Foreground" Value="White"/>
						<Setter Property="FontWeight" Value="Bold"/>
						<Setter Property="Padding" Value="10"/>
					</Style>

					<Style TargetType="ListViewItem">
						<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
						<Setter Property="Background" Value="#0F172A"/>
						<Setter Property="Foreground" Value="White"/>
					</Style>
				</ListView.Resources>

				<ListView.View>
					<GridView>
						<GridViewColumn Header="Guest" Width="130" DisplayMemberBinding="{Binding FullName}" />
						<GridViewColumn Header="ID / Passport" Width="130" DisplayMemberBinding="{Binding IdPassport}" />
						<GridViewColumn Header="Email" Width="180" DisplayMemberBinding="{Binding Email}" />
						<GridViewColumn Header="Room" Width="70" DisplayMemberBinding="{Binding RoomNumber}" />
						<GridViewColumn Header="Check-In" Width="130" DisplayMemberBinding="{Binding CheckInDate, StringFormat=dd.MM.yyyy HH:mm}" />
						<GridViewColumn Header="Checked Out" Width="130" DisplayMemberBinding="{Binding CheckOutDate, StringFormat=dd.MM.yyyy HH:mm}" />
					</GridView>
				</ListView.View>
			</ListView>
		</StackPanel>
	</Grid>
</UserControl>