<Window x:Class="Hotel_CheckIn.Views.EditReservationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Reservation"
        Height="520"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="Edit Reservation"
                       FontSize="24"
                       Foreground="White"
                       Margin="0,0,0,20"/>

			<TextBlock Text="Full Name" Foreground="White"/>
			<TextBox x:Name="NameTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="ID / Passport" Foreground="White"/>
			<TextBox x:Name="IdTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="Email" Foreground="White"/>
			<TextBox x:Name="EmailTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="Room Number" Foreground="White"/>
			<TextBox x:Name="RoomTextBox" Height="30" Margin="0,5"/>

			<TextBlock Text="Check-In Date" Foreground="White"/>
			<DatePicker x:Name="CheckInDatePicker" Margin="0,5"/>

			<TextBlock Text="Check-In Time" Foreground="White"/>
			<ComboBox x:Name="CheckInTimeComboBox" Margin="0,5">
				<ComboBoxItem Content="10:00"/>
				<ComboBoxItem Content="11:00"/>
				<ComboBoxItem Content="12:00"/>
				<ComboBoxItem Content="13:00"/>
				<ComboBoxItem Content="14:00"/>
			</ComboBox>

			<TextBlock Text="Check-Out Date" Foreground="White"/>
			<DatePicker x:Name="CheckOutDatePicker" Margin="0,5"/>

			<TextBlock Text="Check-Out Time" Foreground="White"/>
			<ComboBox x:Name="CheckOutTimeComboBox" Margin="0,5">
				<ComboBoxItem Content="10:00"/>
				<ComboBoxItem Content="11:00"/>
				<ComboBoxItem Content="12:00"/>
				<ComboBoxItem Content="13:00"/>
				<ComboBoxItem Content="14:00"/>
			</ComboBox>

			<Button Content="Save Changes"
                    Height="40"
                    Margin="0,20,0,0"
                    Background="#2563EB"
                    Foreground="White"
                    Click="Save_Click"/>
		</StackPanel>
	</Grid>
</Window>